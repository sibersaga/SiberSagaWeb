# SUPABASE CONFIGURATION (Vite client-side variables)
# Isi dengan project URL dan anon/public key dari Supabase project Anda.
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# GEMINI_API_KEY is optional for AI features.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL is optional for self-referential links.
APP_URL="MY_APP_URL"
